# Fail2Ban & Nginx Rate Limit Dashboard
# Copy this file to .env and update values

# Public dashboard port on the host
APP_PORT=8080

# Required for production auth. Use a long random value.
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_STRING

# Container paths backed by docker-compose volumes
DATABASE_PATH=/app/data/dashboard.db

# Host log/config files mounted into the backend container
NGINX_ACCESS_LOG=/host/nginx/domain_access.log
NGINX_ERROR_LOG=/host/nginx/domain_error.log
FAIL2BAN_LOG=/host/fail2ban.log
BLOCK_FILE_PATH=/host/fail2ban_blocked.conf

# Disable generated demo data for real deployments
DEMO_MODE=false

# Only used when the database is created for the first time
DEFAULT_ADMIN_USER=admin
DEFAULT_ADMIN_PASS=admin
