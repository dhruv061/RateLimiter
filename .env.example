# Fail2Ban & Nginx Rate Limit Dashboard
# Copy this file to .env and update values

# Application
APP_PORT=8080
APP_ENV=production
APP_NAME=Fail2Ban Dashboard
PUBLIC_DIR=/app/public

# Authentication
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_STRING
JWT_EXPIRY=24h

# Database
DATABASE_PATH=/app/data/dashboard.db

# Log File Paths (container paths)
NGINX_ACCESS_LOG=/host/nginx/domain_access.log
NGINX_ERROR_LOG=/host/nginx/domain_error.log
FAIL2BAN_LOG=/host/fail2ban.log
BLOCK_FILE_PATH=/host/fail2ban_blocked.conf

# Demo Mode (generates fake data for testing)
DEMO_MODE=true

# Default Admin (only used on first run)
DEFAULT_ADMIN_USER=admin
DEFAULT_ADMIN_PASS=admin

# GeoIP Provider
GEOIP_PROVIDER=ip-api

# Logging
LOG_LEVEL=info
LOG_PATH=/app/logs/dashboard.log
